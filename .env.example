# Backend API base URL
# Local development (direct to backend dev server):
VITE_API_BASE_URL=http://localhost:3000
# NOTE (local browser smoke testing): :5173 -> :3000 is CROSS-ORIGIN. The backend
# allows this in LOCAL DEV ONLY via a dev-gated CORS middleware (it reflects
# localhost origins + the x-dev-* headers with credentials, and is a NO-OP in any
# real-data/production environment). Production is same-origin via vercel.json
# rewrites, so no CORS is involved there.

# Same-origin production/staging (Vercel custom domain — browser auth smoke works):
# VITE_API_BASE_URL=""
# (empty string = same-origin; /api/* rewrites in vercel.json proxy to backend)
# Required for: https://dashboard.aiautomations.ae

# Direct backend staging URL (API-only, cross-domain — browser auth smoke NOT possible):
# VITE_API_BASE_URL=https://ai-reception-saas.vercel.app

# Active business ID for development (UUID from backend database)
# Required for API calls until auth/session integration is complete.
# When set, business-context.tsx uses it directly and SKIPS GET /api/businesses
# entirely (so the "Workspace unavailable" path cannot trigger). It is also sent
# as the backend `x-dev-business-id` header (see VITE_DEV_AUTH_SESSION below), so
# it must be a REAL business UUID from your local backend database.
# VITE_DEV_BUSINESS_ID=

# Dev-only auth session bypass + backend dev auth headers (LOCAL SMOKE TESTING ONLY)
# When set to exactly "true" AND running under `vite dev` (import.meta.env.DEV),
# this single flag enables TWO local-dev behaviors:
#   1. useAuthSession() returns a synthetic local dev user and skips
#      /api/auth/session (no Google OAuth needed) — see src/hooks/use-auth-session.ts.
#   2. The API client attaches backend `x-dev-*` auth headers to every /api/* call
#      from the VITE_DEV_* values below, so the local backend dev-header auth
#      adapter can resolve authenticated/tenant context — see src/lib/dev-auth-headers.ts.
# It adds NO real auth/OAuth and NO secrets, and is INACTIVE in production builds
# (import.meta.env.DEV is false there → dead-code-eliminated). Leave disabled by default.
#
# Backend prerequisites for (2) to take effect (local backend on :3000, `next dev`):
#   ENABLE_API_HANDLERS="true"
#   ENABLE_DEV_AUTH_CONTEXT="true"
#   ENABLE_AUTHJS_REQUEST_CONTEXT must NOT be "true" (else the Auth.js adapter is
#   selected and the x-dev-* headers are ignored)
#   a valid DATABASE_URL (an unset/invalid DATABASE_URL makes the backend throw 500)
VITE_DEV_AUTH_SESSION=""

# Backend dev auth header values (LOCAL SMOKE TESTING ONLY).
# Only used when VITE_DEV_AUTH_SESSION="true" under `vite dev`. Each maps to a
# backend `x-dev-*` header. Leave empty/disabled by default.
#   VITE_DEV_USER_ID       -> x-dev-user-id. Must be UUID-shaped (it is written to
#                             @db.Uuid columns on create/verify). Not FK-checked, so
#                             any valid UUID works; use a REAL backend user UUID if
#                             you also want audit rows (fire-and-forget) to persist.
#   VITE_DEV_MEMBERSHIP_ID -> x-dev-membership-id. Not persisted; any non-empty value
#                             works (a UUID is recommended for consistency).
#   VITE_DEV_ROLE          -> x-dev-role. One of OWNER | ADMIN | OPERATOR | VIEWER.
#                             OWNER grants the full knowledge create/verify/archive flow.
# (x-dev-business-id is sourced from VITE_DEV_BUSINESS_ID above.)
# VITE_DEV_USER_ID=
# VITE_DEV_MEMBERSHIP_ID=
# VITE_DEV_ROLE=
