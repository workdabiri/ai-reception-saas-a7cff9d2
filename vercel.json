{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "https://ai-reception-saas.vercel.app/api/auth/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://ai-reception-saas.vercel.app/api/:path*"
    }
  ]
}
