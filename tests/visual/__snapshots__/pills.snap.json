  "channel-state-tag/connecting": "<span class=\"inline-flex h-6 items-center gap-1.5 rounded-full px-2.5 text-[11px] font-medium\" style=\"background:color-mix(in oklab, var(--warning) 15%, transparent);color:var(--foreground);border:0.5px solid color-mix(in oklab, var(--warning) 25%, transparent)\" data-channel-state=\"connecting\"><span class=\"h-1.5 w-1.5 rounded-full\" style=\"background:var(--warning);animation:ch-pulse 1.5s ease-in-out infinite\"></span>Connecting…<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-loader-circle ml-0.5 h-3 w-3 animate-spin\" aria-hidden=\"true\" style=\"color:var(--warning)\"><path d=\"M21 12a9 9 0 1 1-6.219-8.56\"></path></svg></span>",
